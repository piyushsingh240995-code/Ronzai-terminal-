rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation Blueprints
    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'createdAt', 'createdBy']) &&
             data.name is string && data.name.size() <= 64;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'isOnline']) &&
             data.displayName is string && data.displayName.size() <= 64;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp', 'type', 'isGhost']) &&
             data.keys().size() == 6 &&
             data.text is string && data.text.size() <= 3000 &&
             data.senderId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUser(incoming());
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      // Allow creation of the public room if it's correctly shaped
      allow create: if isSignedIn() && (
        (roomId == 'public' && incoming().name == 'Public Square' && incoming().createdBy == 'system') ||
        (roomId != 'public' && isValidRoom(incoming()) && incoming().createdBy == request.auth.uid)
      );
      // Only allow minor updates or restrict entirely to prevent hijacking
      allow update: if isSignedIn() && (
        (roomId == 'public' && incoming().name == 'Public Square') ||
        (roomId != 'public' && isOwner(resource.data.createdBy) && isValidRoom(incoming()))
      );
    }

    match /rooms/{roomId}/messages/{messageId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }
  }
}
